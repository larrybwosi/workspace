{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "shell:default",
    "shell:allow-open",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "deep-link:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**/*",
        "$DOCUMENT/**/*"
      ]
    },
    "store:default",
    "process:default"
  ]
}