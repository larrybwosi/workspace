{
  "productName": "Skryme",
  "version": "0.1.0",
  "identifier": "com.skryme.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skryme",
        "width": 1200,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Skryme",
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/your-username/your-repo/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "notification": {},
    "deep-link": {
      "schemes": [
        "skryme"
      ]
    },
    "sql": {
      "db": "sqlite:workspace.db"
    },
    "updater": {},
    "fs": {
      "scope": [
        "$APPDATA/**",
        "$DOWNLOAD/**"
      ]
    },
    "os": {},
    "store": {},
    "process": {}
  }
}
