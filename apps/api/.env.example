# --- Required ---
# Database Credentials (used to build DATABASE_URL in Docker)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=main

# The database connection string (PostgreSQL)
# For Docker: This is automatically built in docker-compose.prod.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/main?schema=public

# Redis Credentials (used to build REDIS_URL in Docker)
REDIS_PASSWORD=

# The Redis connection string
# For Docker: This is automatically built in docker-compose.prod.yml
REDIS_URL=redis://localhost:6379

# Secret for Better Auth (minimum 32 characters)
BETTER_AUTH_SECRET=a_very_long_and_secure_secret_at_least_32_chars
# Port for the API server
PORT=3000

# --- Global / Shared ---
# Environment mode (development, production, test)
NODE_ENV=development
# URL of the web application
NEXT_PUBLIC_APP_URL=http://localhost:3001
# URL of this API application
NEXT_PUBLIC_API_URL=http://localhost:3000
# Better Auth base URL (defaults to NEXT_PUBLIC_API_URL)
BETTER_AUTH_URL=http://localhost:3000
# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3001

# --- Optional: Realtime ---
# Realtime provider (ably, socketio)
REALTIME_PROVIDER=ably
# Ably API key (required if REALTIME_PROVIDER=ably)
ABLY_API_KEY=

# --- Optional: Storage ---
# Storage provider (sanity, minio)
STORAGE_PROVIDER=sanity
# Sanity configuration
SANITY_WRITE_TOKEN=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Minio configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=uploads

# --- Optional: OAuth Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# --- Optional: Notifications & Integrations ---
# Agora configuration for voice/video calls
AGORA_APP_CERTIFICATE=
NEXT_PUBLIC_AGORA_APP_ID=
# Firebase Admin configuration
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Dodo Payments webhook secret
DODO_PAYMENTS_WEBHOOK_SECRET=
# Expo access token for push notifications
EXPO_ACCESS_TOKEN=
# Desktop notification endpoint
DESKTOP_NOTIFICATION_ENDPOINT=http://localhost:3005

# --- Optional: Security & Internal ---
# Secret for bot token generation
BOT_TOKEN_SECRET=change-me-to-a-random-secret
# Secret for incoming webhooks
WEBHOOK_SECRET=change-me-to-a-random-secret
# Whether to export OpenAPI spec on startup
EXPORT_OPENAPI=false
