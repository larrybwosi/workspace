# --- Required ---
# The database connection string (PostgreSQL)
# For Docker: postgresql://postgres:postgres@postgres:5432/main?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/main?schema=public
# The Redis connection string
# For Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379
# Secret for Better Auth (minimum 32 characters)
BETTER_AUTH_SECRET=a_very_long_and_secure_secret_at_least_32_chars
# Better Auth base URL
BETTER_AUTH_URL=http://localhost:3000
# URL of the API server
# NOTE: In Docker Compose, use http://api:3000 for SSR
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Global / Shared ---
# Environment mode (development, production, test)
NODE_ENV=development
# URL of this web application
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Optional: Storage & CMS ---
# Sanity configuration
SANITY_WRITE_TOKEN=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# --- Optional: Realtime & Notifications ---
# Realtime provider (ably, socketio)
NEXT_PUBLIC_REALTIME_PROVIDER=ably
# Firebase client configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Optional: Voice/Video Call (Agora) ---
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# --- Optional: Security & Internal ---
# Secret for bot token generation
BOT_TOKEN_SECRET=default_secret
# Dodo Payments webhook secret
DODO_PAYMENTS_WEBHOOK_SECRET=
