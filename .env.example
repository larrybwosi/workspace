# --- Deployment Configuration ---
# Docker Registry and Repository Info
DOCKER_REGISTRY=ghcr.io
GITHUB_REPOSITORY_OWNER=scrymechat
REPO_NAME=workspace
APP_VERSION=latest

# --- Database (PostgreSQL) ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=main
# NOTE: In Docker Compose, DATABASE_URL is automatically constructed from the above variables.
# If running locally, you might need to set this manually:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/main?schema=public

# --- Redis ---
REDIS_PASSWORD=
# NOTE: In Docker Compose, REDIS_URL is automatically constructed.
# If running locally, you might need to set this manually:
# REDIS_URL=redis://localhost:6379

# --- General App Settings ---
NODE_ENV=production
# The public URL of the web application
NEXT_PUBLIC_APP_URL=http://localhost:3001
# The URL of the API server
# NOTE: For Server-Side Rendering (SSR) to work correctly within Docker Compose,
# this should be set to 'http://api:3000' so the web container can reach the api container.
NEXT_PUBLIC_API_URL=http://api:3000
PORT=3000

# --- Authentication (Better Auth) ---
# Secret for Better Auth (minimum 32 characters)
BETTER_AUTH_SECRET=a_very_long_and_secure_secret_at_least_32_chars
# Better Auth base URL (usually the API URL)
BETTER_AUTH_URL=http://api:3000

# --- Security ---
ALLOWED_ORIGINS=http://localhost:3001
BOT_TOKEN_SECRET=change-me-to-a-random-secret
WEBHOOK_SECRET=change-me-to-a-random-secret

# --- Optional: Realtime & Notifications ---
# Realtime provider (ably, socketio)
REALTIME_PROVIDER=ably
NEXT_PUBLIC_REALTIME_PROVIDER=ably
# Ably API key (required if REALTIME_PROVIDER=ably)
ABLY_API_KEY=

# --- Optional: Storage & CMS ---
# Storage provider (sanity, minio)
STORAGE_PROVIDER=sanity
SANITY_WRITE_TOKEN=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Minio configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=uploads

# --- Optional: Firebase ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Optional: Voice/Video Call (Agora) ---
AGORA_APP_ID=
NEXT_PUBLIC_AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# --- Optional: OAuth Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# --- Other ---
DODO_PAYMENTS_WEBHOOK_SECRET=
EXPO_ACCESS_TOKEN=
DESKTOP_NOTIFICATION_ENDPOINT=http://localhost:3005
EXPORT_OPENAPI=false
