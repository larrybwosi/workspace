{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "rootDir": "src",
    "jsx": "react-jsx",
    "paths": {
      "@repo/ui/components/*": [
        "./src/components/*"
      ],
      "@repo/ui/lib/*": [
        "./src/lib/*"
      ],
      "@repo/ui/hooks/*": [
        "./src/hooks/*"
      ],
      "@repo/ui/*": [
        "./src/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}