{
  "name": "@repo/database",
  "version": "0.0.691",
  "private": true,
  "main": "./index.ts",
  "scripts": {
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "dotenv -e .env -- prisma db push",
    "prepare": "[ -f prisma/schema.prisma ] && pnpm db:generate || echo 'Schema not found, skipping generation'",
    "test": "echo 'No tests for database'"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "prisma": "7.8.0",
    "typescript": "^6.0.2"
  }
}
