{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/index.{ts,tsx,js,jsx,mjs}",
    "src/main.{ts,tsx,js,jsx,mjs}",
    "src/mcp-main.{ts,tsx,js,jsx,mjs}",
    "src/app/**/page.{ts,tsx,js,jsx,mjs}",
    "src/app/**/route.{ts,tsx,js,jsx,mjs}",
    "src/app/**/layout.{ts,tsx,js,jsx,mjs}"
  ],
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "ignorePatterns": [
    "**/generated/**",
    "**/dist/**",
    "**/.next/**"
  ],
  "duplicates": {
    "ignore": [
      "**/generated/**"
    ]
  },
  "rules": {}
}
